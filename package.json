{
  "name": "cine-make",
  "version": "0.0.5",
  "private": false,
  "type": "module",
  "description": "Local AI short-drama pre-production factory: compact deliverable, optional storyboard images, and video-model prompt packs.",
  "license": "MIT",
  "keywords": [
    "codex",
    "skill",
    "storyboard",
    "video-preproduction",
    "image-generation",
    "seedance",
    "jimeng",
    "director-workflow"
  ],
  "bin": {
    "cine-make": "bin/cine-make.mjs"
  },
  "files": [
    "bin/",
    "examples/",
    "product/",
    "prompts/",
    "scripts/",
    "skills/",
    "src/",
    "README.md",
    "README.zh-CN.md",
    "docs/"
  ],
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "make": "node src/cli.mjs",
    "render:images": "node scripts/render-images.mjs",
    "validate": "node scripts/validate-run.mjs",
    "install:skill": "node scripts/install-codex-skill.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
